---
import Logo from './Logo.astro';

const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Start' },
  { href: '/rezepte', label: 'Rezepte' },
  { href: '/flame-levels', label: 'Flame Levels' },
  { href: '/ueber', label: 'Über' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-coal-900/80 border-b border-coal-600/20">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <Logo size="sm" showTagline={false} />

    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-body font-medium tracking-wide transition-colors duration-200',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-flame-500'
              : 'text-coal-200 hover:text-flame-400'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <button id="mobile-toggle" class="md:hidden p-2 text-coal-200 hover:text-flame-400 transition-colors" aria-label="Menü öffnen">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-coal-600/20 bg-coal-800/95 backdrop-blur-xl">
    <div class="px-4 py-4 flex flex-col gap-3">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-base font-body py-2 px-3 rounded-lg transition-colors',
            currentPath === link.href
              ? 'text-flame-500 bg-flame-500/10'
              : 'text-coal-200 hover:text-flame-400 hover:bg-coal-700/50'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
